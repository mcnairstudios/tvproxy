#!/bin/bash
set -e

PUID=${PUID:-1000}
PGID=${PGID:-1000}

# If a GPU render device exists, run as its group so ffmpeg can access it
if [ -e /dev/dri/renderD128 ]; then
  PGID=$(stat -c '%g' /dev/dri/renderD128)
fi

# Update tvproxy group/user to match requested IDs
if [ "$(id -g tvproxy)" != "$PGID" ]; then
  groupmod -o -g "$PGID" tvproxy
fi
if [ "$(id -u tvproxy)" != "$PUID" ]; then
  usermod -o -u "$PUID" tvproxy
fi

# Ensure /data and /record are writable
chown "$PUID:$PGID" /data
mkdir -p /record
chown "$PUID:$PGID" /record

# Set up WireGuard tunnel if configured
if [ -n "$WG_PRIVATE_KEY" ]; then
  echo "Setting up WireGuard tunnel..."

  # Write private key to temp file
  WG_KEY_FILE=$(mktemp)
  echo "$WG_PRIVATE_KEY" > "$WG_KEY_FILE"
  chmod 600 "$WG_KEY_FILE"

  # Clean up any leftover interface from previous run
  ip link del wg0 2>/dev/null || true

  # Create interface manually (no wg-quick, no policy routing)
  ip link add wg0 type wireguard
  wg set wg0 private-key "$WG_KEY_FILE" peer "$WG_PEER_PUBLIC_KEY" endpoint "$WG_PEER_ENDPOINT" allowed-ips "0.0.0.0/0"
  ip addr add "$WG_ADDRESS" dev wg0
  ip link set mtu 1420 up dev wg0

  rm -f "$WG_KEY_FILE"

  # Route specific hosts/CIDRs through the tunnel
  # WG_ROUTE_HOSTS: comma-separated hostnames to resolve and route (e.g. "t.41rpa.uk,other.host")
  # WG_ROUTE_CIDRS: comma-separated IPs/CIDRs to route (e.g. "45.155.90.0/24,103.0.0.0/8")
  if [ -n "$WG_ROUTE_HOSTS" ]; then
    for host in $(echo "$WG_ROUTE_HOSTS" | tr ',' ' '); do
      for ip in $(getent ahostsv4 "$host" | awk '{print $1}' | sort -u); do
        echo "Routing $ip ($host) via wg0"
        ip route add "$ip/32" dev wg0 2>/dev/null || true
      done
    done
  fi

  if [ -n "$WG_ROUTE_CIDRS" ]; then
    for cidr in $(echo "$WG_ROUTE_CIDRS" | tr ',' ' '); do
      echo "Routing $cidr via wg0"
      ip route add "$cidr" dev wg0 2>/dev/null || true
    done
  fi

  echo "WireGuard tunnel active"
fi

exec gosu tvproxy tvproxy "$@"
